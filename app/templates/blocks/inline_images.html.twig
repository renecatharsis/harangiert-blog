{% set lightboxSelector = 'lightbox-' ~ random() %}

{% if block.images|length == 3 %}
    {% set format = '243x182' %}
    {% set width = '243' %}
    {% set height = '182' %}
{% elseif block.images|length == 2 %}
    {% set format = '370x277' %}
    {% set width = '370' %}
    {% set height = '277' %}
{% else %}
    {% set format = '408x306' %}
    {% set width = '408' %}
    {% set height = '306' %}
{% endif %}

<div class="flex gap-1 {{ block.images|length == 1 ? 'justify-center' : 'justify-between' }}">
    {% for image in block.images %}
    <a href="{{ image.formats['1920x1080'] }}" title="{{ image.title }}" target="_blank" rel="noopener" class="glightbox" data-gallery="{{ lightboxSelector }}" data-glightbox="type: image">
        <img alt="{{ image.title }}" width="{{ width }}" height="{{ height }}" src="{{ image.formats[format] }}" class="img-thumbnail border-white border-1 p-1"/>
    </a>
    {% endfor %}
</div>